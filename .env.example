# Tally — Environment Variables
# Copy this file to .env and fill in values from Firebase Console → Project settings → Your apps.

# ─── Firebase (required for v1.2+) ───────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: only if deploying under a subpath (not needed for Amplify root hosting)
# VITE_BASE_URL=/
