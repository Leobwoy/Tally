# Tally — Environment Variables
# Copy this file to .env and fill in your values after setting up AWS.
# The app works fully offline without these — AWS sync is optional until you set it up.

# GitHub Pages (https://username.github.io/Tally/) — use when building for project Pages:
# VITE_BASE_URL=/Tally/

# AWS Region (e.g. us-east-1, eu-west-1, af-south-1)
VITE_AWS_REGION=

# Cognito User Pool ID (from AWS Console → Cognito → User Pools)
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (from User Pool → App clients)
VITE_COGNITO_CLIENT_ID=

# HTTP API Gateway URL (from AWS Console → API Gateway → your API → Invoke URL)
# Example: https://abc123xyz.execute-api.us-east-1.amazonaws.com
VITE_API_URL=
